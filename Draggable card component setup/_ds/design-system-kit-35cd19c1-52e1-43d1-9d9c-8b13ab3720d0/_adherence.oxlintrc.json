      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:standard|bordered|elevated)$/]",
        "message": "<Card> variant must be one of 'standard' | 'bordered' | 'elevated'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|small|medium|large)$/]",
        "message": "<Card> padding must be one of 'none' | 'small' | 'medium' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChartSeries'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|data|color|dashStyle|key|ref|className|style|children)$/]",
